# Friendli: capability gap detection + draft generation
FRIENDLI_API_KEY="replace-with-friendli-api-key"
FRIENDLI_BASE_URL="https://api.friendli.ai/serverless/v1"
FRIENDLI_MODEL="meta-llama-3.1-8b-instruct"

# ClawHub: direct public registry retrieval + SKILL.md fetch
CLAWHUB_BASE_URL="https://clawhub.ai"
CLAWHUB_BIN="clawhub"
CLAWHUB_SEARCH_LIMIT="5"
CLAWHUB_DOCS_LIMIT="3"
CLAWHUB_MIN_SEARCH_SCORE="1.2"
CLAWHUB_NON_SUSPICIOUS_ONLY="true"
CLAWHUB_SKILL_FILE_PATH="SKILL.md"
CLAWHUB_TAG="latest"
CLAWHUB_CACHE_TTL_SECONDS="3600"

# Redis: cross-agent cache
ENABLE_REDIS="false"
REDIS_URL="redis://localhost:6379"
SKILL_CACHE_TTL_SECONDS="300"

# Runtime sandbox
SANDBOX_ROOT="/tmp/autoskill"
EXECUTION_TIMEOUT_SECONDS="30"

# Optional legacy docs fallback
ENABLE_APIFY="false"
APIFY_API_TOKEN="replace-with-apify-api-token"
APIFY_BASE_URL="https://api.apify.com/v2"
APIFY_DOCS_ACTOR_ID="docs-crawler"
APIFY_WAIT_FOR_FINISH_SECONDS="60"
APIFY_INTENDED_USAGE_TEMPLATE="Resolve or synthesize a skill for capability: {capability}."
APIFY_IMPROVEMENT_SUGGESTIONS="Return structured skill metadata and detailed content relevant to the requested capability."
APIFY_CONTACT=""
APIFY_MAX_ITEMS="25"
APIFY_DOWNLOAD_CONTENT="true"

# Shared adapter HTTP timeout
HTTP_TIMEOUT_SECONDS="30"
